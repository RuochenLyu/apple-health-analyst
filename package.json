{
  "name": "apple-health-analyst",
  "version": "1.1.1",
  "description": "Privacy-first Apple Health export analyzer. Parses HealthKit data locally, generates cross-metric insights, and renders professional health reports (HTML/Markdown) with bilingual support. Designed as an agent skill for Codex and Claude Code.",
  "type": "module",
  "bin": {
    "apple-health-analyst": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "apple-health",
    "healthkit",
    "health-report",
    "quantified-self",
    "apple-watch",
    "cli",
    "codex-skill",
    "agent-skills",
    "claude-code-skill",
    "skill"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuochenLyu/apple-health-analyst.git"
  },
  "homepage": "https://ruochenlyu.github.io/apple-health-analyst/",
  "bugs": {
    "url": "https://github.com/RuochenLyu/apple-health-analyst/issues"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    ".agents/skills/apple-health-analyst",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "saxes": "^6.0.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/unzipper": "^0.10.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
